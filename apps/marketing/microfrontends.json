{
    "$schema": "https://openapi.vercel.sh/microfrontends.json",
    "applications": {
        "acme-dashboard": {
            "packageName": "@acme/dashboard",
            "routing": [
                {
                    "paths": [
                        "/app",
                        "/app/:path*",
                        "/settings",
                        "/settings/:path*"
                    ]
                }
            ],
            "development": {
                "local": 3002
            }
        },
        "acme-docs": {
            "packageName": "@acme/docs",
            "routing": [
                {
                    "paths": [
                        "/docs",
                        "/docs/:path*"
                    ]
                }
            ],
            "development": {
                "local": 3001
            }
        },
        "acme-marketing": {
            "packageName": "@acme/marketing",
            "development": {
                "local": 3000,
                "fallback": "http://localhost:3000"
            }
        }
    },
    "options": {
        "localProxyPort": 3024
    }
}