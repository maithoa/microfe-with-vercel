{
    "$schema": "https://openapi.vercel.sh/microfrontends.json",
    "applications":{
        "@acme-marketing":{
            "packageName": "@acme/marketing",
            "development":{
                "fallback": "http://localhost:3000",
                "local": 3000
            }
        },
        "@acme-docs":{
            "packageName": "@acme/docs",
            "routing":[
                {
                    "paths": ["/docs", "/docs/:path*"]
                }
            ],
            "development":{
                "local": 3001
            }
        },
        "@acme-dashboard":{
            "packageName": "@acme/dashboard",
            "routing":[
                {
                    "paths": ["/app", "/app/:path*", "/settings", "/settings/:path*"]
                }
            ],
            "development":{
                "local": 3002
            }        
        }
    },
    "options":{
        "localProxyPort": 3024
    }
}